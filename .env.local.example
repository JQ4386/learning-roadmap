# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local
# ---------------------------------------------------------------------------

# --- Supabase (client-safe; the anon key is public by design) ---
# Vercel's Supabase integration injects these into your deployment automatically.
# For local dev, copy from Supabase dashboard > Project Settings > API.
# Security is enforced by Row-Level Security + Auth, not by hiding these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Gemini scout (SERVER ONLY — must NOT start with NEXT_PUBLIC_) ---
# From Google AI Studio. Keep billing DISABLED on this project to retain the
# free tier (enabling billing deletes the free tier — see README).
GEMINI_API_KEY=

# Optional: override the scout model (defaults to gemini-3.5-flash,
# falls back to gemini-3-flash automatically if unavailable).
# GEMINI_MODEL=gemini-3.5-flash
